PORT=5500
MONGODB_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/database_name"
JWT_SECRET="your_jwt_secret_here"

CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Gemini API Key for translation feature
GEMINI_API_KEY="your_gemini_api_key_here"

# Hugging Face API Key (optional - for AI features)
HF_API_KEY="your_hf_api_key_here"

# Cloudflare Workers AI - for AI image generation
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"
CLOUDFLARE_API_TOKEN="your_cloudflare_api_token"
